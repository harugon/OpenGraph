{
  "name": "harugon/open-graph",
  "type": "mediawiki-extension",
  "description": "MediaWiki OpenGraph,Twitter Card",
  "keywords": [
    "MediaWiki",
    "OpenGrap",
    "Twitter Card",
    "Twitter"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "harugon",
      "email": "info@harugon.com",
      "role": "Developer"
    }
  ],
  "require": {
    "php": ">=8.3.0",
    "composer/installers": "^2.0 || ^1.0"
  },
  "require-dev": {
    "mediawiki/mediawiki-codesniffer": "51.0.0",
    "mediawiki/minus-x": "1.1.3",
    "ockcyp/covers-validator": "1.6.0",
    "php-parallel-lint/php-console-highlighter": "1.0.0",
    "php-parallel-lint/php-parallel-lint": "1.4.0",
    "phpunit/phpunit": "^9.6.1"
  },
  "scripts": {
    "test": [
      "parallel-lint . --exclude vendor",
      "phpunit",
      "covers-validator",
      "@phpcs",
      "minus-x check ."
    ],
    "cover": "phpunit --coverage-html coverage",
    "fix": [
      "minus-x fix .",
      "phpcbf"
    ],
    "phpcs": "phpcs -sp"
  },
  "autoload": {
    "psr-4": {
      "MediaWiki\\Extension\\OpenGraph\\": "includes/"
    }
  },
  "bin-dir" : "/vendor/bin/",
  "extra": {
    "installer-name": "OpenGraph"
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true,
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
